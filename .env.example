# Docker: Postgres en el contenedor escucha en 5432; en tu PC suele mapearse a 5433.
# Ver docker-compose.yml (linea ports: "5433:5432").
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/estudio_uy?schema=public"
#
# Si DATABASE_URL queda en :5432 por error, en desarrollo la app redirige a :5433 sola.
# Postgres instalado en Windows en 5432 (sin Docker en 5433): DATABASE_URL_USE_LOCAL_PG_5432=1

# Secreto para firmar la sesion (JWT). Minimo 32 caracteres en produccion.
AUTH_SECRET="cambiar-por-secreto-minimo-32-caracteres-seguros"

# Cookie de sesion con flag Secure (solo HTTPS). En produccion por HTTP (p. ej. EC2 sin SSL): 0
# Con HTTPS (Certbot): no pongas esta linea o usa 1.
# AUTH_COOKIE_SECURE=0
